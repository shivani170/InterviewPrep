							},
							"content": [
								{
									"type": "text",
									"text": "let i = 0"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "while(i < arr.length){"
								}
							]
						},
